---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../config/site';

const { branding } = siteConfig;

const meetups = [
  { name: 'React Berlin', city: 'Berlin', url: 'https://www.meetup.com/React-Berlin/' },
  { name: 'React Munich', city: 'Munich', url: 'https://www.meetup.com/React-Munich/' },
  { name: 'React Hamburg', city: 'Hamburg', url: 'https://www.meetup.com/React-Hamburg/' },
  { name: 'React Cologne', city: 'Cologne', url: 'https://www.meetup.com/React-Cologne/' },
  { name: 'React Frankfurt', city: 'Frankfurt', url: 'https://www.meetup.com/React-Frankfurt/' },
  { name: 'React Stuttgart', city: 'Stuttgart', url: 'https://www.meetup.com/React-Stuttgart/' },
  { name: 'React Vienna', city: 'Vienna', url: 'https://www.meetup.com/React-Vienna/' },
  { name: 'React Zurich', city: 'Zurich', url: 'https://www.meetup.com/React-Zurich/' },
];
---

<BaseLayout
  title="React Meetups"
  description="Find your React Meetup in the DACH region or start your own!"
>
  <section class="relative py-20 md:py-28 overflow-hidden dark:bg-gray-950">
    <div class="absolute inset-0 dark:hidden" style={`background: ${branding.heroGradientLight}`}></div>
    <div class="absolute inset-0 hidden dark:block" style={`background: ${branding.heroGradientDark}`}></div>
    <div class="absolute inset-0 dark:opacity-30" style="background-image: radial-gradient(circle, rgba(0, 0, 0, 0.08) 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="container mx-auto px-4 relative text-center z-10">
      <h1 class="text-5xl md:text-6xl lg:text-7xl text-gray-900 dark:text-white mb-4">
        <span class="block">React</span>
        <span class="text-primary">Meetups.</span>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Find your React Meetup in the DACH region<br />
        and connect with the community.
      </p>
    </div>
  </section>

  <section class="py-12 dark:bg-gray-950">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-12">
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          The DACH region (Germany, Austria, Switzerland) has a vibrant React community with regular meetups
          in many cities. These events are a great opportunity to exchange ideas with other React developers,
          learn from talks and workshops, discover new libraries and tools, and make valuable professional contacts.
        </p>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          Most meetups feature a mix of lightning talks, longer presentations, and open networking time. Topics
          range from React fundamentals and hooks to advanced subjects like server components, state management
          with Zustand or Redux, testing strategies, and full-stack development with Next.js. Whether you're a
          beginner or a seasoned React developer, there's always something new to learn and people to meet.
        </p>
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          ReactJS.DE supports the local meetup scene as part of our mission to strengthen the German-speaking
          React community. We help organizers with promotion, speaker coordination, and connecting meetup groups
          across the region.
        </p>
        <p class="text-gray-600 dark:text-gray-400">
          Want to start a meetup in your city? We'd love to support you!
          Contact us via our <a href="/discord/" class="text-primary hover:underline">Discord</a> or join
          our <a href="/newsletter/redirect/hero/" class="text-primary hover:underline">newsletter</a> to
          stay updated on community events.
        </p>
      </div>

      <h2 class="text-2xl text-gray-900 dark:text-white mb-6">Meetups in the DACH Region</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {meetups.map(meetup => (
          <a
            href={meetup.url}
            target="_blank"
            rel="noopener"
            class="group p-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-lg transition-all border border-gray-100 dark:border-gray-700"
          >
            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
              {meetup.name}
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
              📍 {meetup.city}
            </p>
          </a>
        ))}
      </div>

      <div class="mt-12 bg-gray-50 dark:bg-gray-900 rounded-xl p-6">
        <h3 class="text-gray-900 dark:text-white mb-2">Your meetup is not listed?</h3>
        <p class="text-gray-600 dark:text-gray-400">
          If you organize a React meetup and would like to have it listed here,
          contact us via <a href="/discord/" class="text-primary hover:underline">Discord</a> or create a
          Pull Request on <a href="https://github.com/symetics/reactjs.de" target="_blank" rel="noopener" class="text-primary hover:underline">GitHub</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
