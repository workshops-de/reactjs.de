---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const tutorials = [
  {
    slug: 'react-tutorial-for-beginners',
    title: 'React Basics',
    description: 'Tutorial on React 19 - learn the basics of the most popular JavaScript library for building user interfaces with a sample project.',
    icon: '⚛️',
    color: 'from-cyan-500 to-blue-500'
  }
];
---

<BaseLayout
  title="Beginner Tutorials"
  noindex={true}
>
  <section class="bg-gradient-to-br from-primary-50 to-white py-12">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl text-gray-900 mb-2">Beginner Tutorials</h1>
      <p class="text-lg text-gray-600">
        Here we offer you an easy introduction to React, TypeScript and AI Engineering!
      </p>
    </div>
  </section>

  <section class="py-12">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="space-y-4">
        {tutorials.map(tutorial => (
          <a
            href={`/en/articles/${tutorial.slug}/`}
            class="group flex items-center gap-6 p-6 bg-white rounded-xl shadow-sm hover:shadow-lg transition-all"
          >
            <div class={`w-16 h-16 rounded-xl bg-gradient-to-br ${tutorial.color} flex items-center justify-center text-3xl flex-shrink-0`}>
              {tutorial.icon}
            </div>
            <div>
              <h2 class="text-xl font-semibold text-gray-900 group-hover:text-primary transition-colors">
                {tutorial.title}
              </h2>
              <p class="text-gray-600 mt-1">{tutorial.description}</p>
            </div>
            <svg class="w-6 h-6 text-gray-400 group-hover:text-primary transition-colors flex-shrink-0 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
