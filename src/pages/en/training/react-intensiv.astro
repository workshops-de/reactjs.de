---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductJsonLd from '../../../components/ProductJsonLd.astro';
import { siteConfig, buildUtmUrl, getLocalizedCourses } from '../../../config/site';
import courseData from '../../../data/course.json';

const { topic } = siteConfig;
const { providerUrl } = siteConfig.training;
const courses = getLocalizedCourses('en');

const clients = [
  { name: 'RWE', logo: '/shared/assets/img/clients/rwe.svg' },
  { name: 'Commerzbank', logo: '/shared/assets/img/clients/commerzbank.svg' },
  { name: 'Allianz', logo: '/shared/assets/img/clients/allianz.svg' },
  { name: 'Bosch', logo: '/shared/assets/img/clients/bosch.svg' },
  { name: 'Galeria Kaufhof', logo: '/shared/assets/img/clients/galeria-kaufhof.svg' },
  { name: 'SWR', logo: '/shared/assets/img/clients/swr.svg' },
];

const reviews = courseData.review.slice(0, 6).map((review: any) => ({
  stars: review.reviewRating.ratingValue,
  quote: review.reviewBody,
  author: review.author.name,
  date: review.datePublished,
}));

const aggregateRating = courseData.aggregateRating;

const testimonials = [
  {
    quote: 'The trainers are absolute professionals and convey their enthusiasm for the subject. Our employees benefit from intensive, practical training that addresses their needs. The feedback has been exceptionally positive.',
    name: 'Annika Stille',
    role: 'Head of Internal Training',
    company: 'Adesso AG',
    image: '/assets/img/courses/testimonial-annika-stille-adesso.jpg',
  },
  {
    quote: 'The training courses are always aligned with current market topics and tailored to our needs. They help our employees prepare quickly and efficiently for upcoming projects.',
    name: 'Christian Janz',
    role: 'Lead Software Architect',
    company: 'bridgingIT',
    image: '/assets/img/courses/testimonial-christianz-janz.png',
  },
];

const bookingUrl = buildUtmUrl(`${providerUrl}/seminare-schulungen-kurse/react-modul-1`, 'training_2025', 'portal', 'training_page_en');
---

<BaseLayout
  title={`${topic} & TypeScript Intensive Training (On-Site / Remote)`}
  description={`Want to learn ${topic}? Learn together on-site or remotely. Discover our intensive training courses!`}
>
  <ProductJsonLd />

  <!-- Hero Header -->
  <section class="relative py-20 md:py-28 overflow-hidden dark:bg-gray-950">
    <div class="absolute inset-0 dark:hidden" style="background: radial-gradient(at 20% 30%, rgba(97, 218, 251, 0.08) 0px, transparent 50%), radial-gradient(at 80% 20%, rgba(59, 130, 246, 0.1) 0px, transparent 50%), radial-gradient(at 40% 80%, rgba(97, 218, 251, 0.06) 0px, transparent 50%), linear-gradient(180deg, #fafafa 0%, #f5f5f5 100%);"></div>
    <div class="absolute inset-0 hidden dark:block" style="background: radial-gradient(at 20% 30%, rgba(97, 218, 251, 0.2) 0px, transparent 50%), radial-gradient(at 80% 20%, rgba(59, 130, 246, 0.15) 0px, transparent 50%), radial-gradient(at 40% 80%, rgba(97, 218, 251, 0.12) 0px, transparent 50%);"></div>
    <div class="absolute inset-0 dark:opacity-30" style="background-image: radial-gradient(circle, rgba(0, 0, 0, 0.08) 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="container mx-auto px-4 text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 dark:border-gray-600 text-primary-700 dark:text-primary-400 rounded-full text-sm font-medium mb-6 dark:bg-gray-800/50">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        Upcoming dates available
      </div>

      <div class="w-28 h-28 md:w-36 md:h-36 mx-auto mb-8">
        <img
          src="/assets/img/courses/logo-react-typescript.svg"
          alt={`${topic} & TypeScript Training`}
          class="w-full h-full drop-shadow-lg"
        />
      </div>

      <h1 class="text-gray-900 dark:text-white mb-6">
        The best way to start<br />
        with <span class="text-primary">{topic}</span>.
      </h1>

      <p class="text-xl text-gray-600 dark:text-gray-400 mb-4 max-w-2xl mx-auto">
        Our training courses prepare you for productive use of {topic}.
        Trust our expertise like <span class="font-semibold text-gray-900 dark:text-white">2000+ participants</span> before you.
      </p>

      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-sm text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          On-Site
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-sm text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-4 h-4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
          Remote
        </span>
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full text-sm text-gray-600 dark:text-gray-300 shadow-sm">
          <svg class="w-4 h-4 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
          In-House
        </span>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-semibold px-8 py-4 rounded-full hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors shadow-lg"
        >
          Book Training
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
        <a
          href="#courses"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-gray-300 dark:border-gray-600 rounded-full font-semibold text-gray-700 dark:text-gray-300 hover:border-primary hover:text-primary transition-colors"
        >
          View All Courses
        </a>
      </div>
    </div>
  </section>

  <!-- Client Logos -->
  <section class="bg-gray-50 dark:bg-gray-900 border-y border-gray-100 dark:border-gray-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-3 md:grid-cols-6 gap-8 md:gap-12 items-center">
        {clients.map(client => (
          <img
            src={client.logo}
            alt={client.name}
            loading="lazy"
            class="h-10 md:h-14 lg:h-30 w-auto mx-auto grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all dark:invert dark:opacity-60 dark:hover:opacity-70 dark:hover:grayscale"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- All Courses Overview -->
  <section id="courses" class="py-16 scroll-mt-20 dark:bg-gray-950">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto mb-12">
        <h2 class="!text-sm !font-semibold text-primary uppercase !tracking-wide mb-3">Our {topic} Training Courses</h2>
        <p class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          Expand your {topic} knowledge with these courses.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-2 gap-6 justify-center max-w-5xl mx-auto">
        {courses.map(course => (
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 p-6 flex flex-col h-full hover:shadow-lg transition-shadow">
            <div class="flex justify-center mb-4">
              <img
                src={course.icon}
                alt={course.title}
                class="h-16 w-auto"
                loading="lazy"
                onerror={`this.onerror=null; this.src='/assets/img/courses/react-logo.svg'`}
              />
            </div>

            <h3 class="text-lg text-gray-900 dark:text-white text-center mb-1">{course.title}</h3>

            <p class="text-sm text-gray-600 dark:text-gray-400 text-center flex-1 mb-4">
              {course.description}
            </p>

            <div class="flex flex-col items-center gap-2 mb-4">
              <span class="inline-flex items-center gap-1 px-3 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400 text-xs font-medium rounded-full">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                </svg>
                {course.duration}
              </span>
              <span class="inline-flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400">
                <svg class="w-3 h-3 text-pink-500" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                </svg>
                {course.format}
              </span>
            </div>

            <a
              href={buildUtmUrl(`${providerUrl}${course.url}`, 'training_2025', 'portal', 'course_card_en')}
              target="_blank"
              rel="noopener"
              class="block w-full text-center bg-primary hover:bg-primary-dark text-white font-medium py-3 px-4 rounded-lg transition-all"
            >
              View Training
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-gray-500 dark:text-gray-400 mt-8">
        All training courses are provided by
        <img src="/shared/assets/img/workshops-de-logo.svg" alt="workshops.de" class="inline h-5 mx-1 align-middle" loading="lazy" />
        <a href={buildUtmUrl(providerUrl, 'training_2025', 'portal', 'provider_link_en')} target="_blank" rel="noopener" class="text-primary hover:underline font-medium">workshops.de</a>.
      </p>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-20 dark:bg-gray-950">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-3">Interactive Workshop</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl text-gray-900 dark:text-white mb-8 leading-tight">
          Learn faster and more enjoyably.
        </h2>

        <div class="prose prose-lg dark:prose-invert max-w-none mb-12">
          <p>
            {topic} is the most popular library for building modern user interfaces and numerous companies now rely on {topic} in production.
            Whether single-page applications, complex dashboards, or mobile apps with React Native – the possibilities are enormous.
            With version 19, {topic} has once again excelled with innovative features like the new Compiler, Server Components, and Actions.
          </p>
          <p>
            In our {topic} training, we teach the fundamentals of the framework and show our participants
            how to plan and professionally set up a project.
          </p>
          <p>
            We offer both public and private workshops. Public workshops have fixed dates and are open to anyone.
            Private (in-house) training is arranged upon request and is fully customized in terms of schedule and content.
          </p>
          <p>
            We currently focus on part-time formats with 6-day workshops.
            This way you can continue working on your projects without being completely unavailable.
            Developers especially can rarely take an entire week off.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-start max-w-5xl mx-auto">
        <ul class="space-y-2">
          {[
            '60% hands-on practice',
            'Sample solutions for all exercises',
            `Up-to-date content based on ${topic} 19`,
            'Plenty of time for questions',
            'Time for group work and breakout sessions',
            'Interactive meetings for questions and discussions',
            'Permanent access to materials, recordings, and transcripts',
          ].map(item => (
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-gray-700 dark:text-gray-300">{item}</span>
            </li>
          ))}
        </ul>

        <img
          src="/assets/img/courses/attendees.jpg"
          alt="Workshop Participants"
          loading="lazy"
          class="rounded-lg shadow-lg w-full"
        />
      </div>
    </div>
  </section>

  <!-- What is React/TypeScript -->
  <section class="py-20 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-3">What are {topic} and TypeScript?</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl text-gray-900 dark:text-white mb-16 leading-tight">
          A brief overview of<br />what it's all about.
        </h2>
      </div>

      <div class="space-y-12 max-w-5xl mx-auto">
        <div class="flex gap-6 items-start">
          <img src="/assets/img/courses/react-logo.svg" alt="React Logo" loading="lazy" class="w-16 h-16 flex-shrink-0" />
          <div>
            <h3 class="text-xl text-gray-900 dark:text-white mb-3">{topic}</h3>
            <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
              {topic} is a JavaScript library developed by Meta (Facebook) for building user interfaces.
              It is characterized by its component-based approach, the Virtual DOM, and a declarative programming model.
              With React 19, the library offers modern features like Server Components, the new React Compiler, and Actions
              for even more productive development. {topic} is the most widely used UI library worldwide and forms the basis
              for frameworks like Next.js and Remix.
            </p>
          </div>
        </div>

        <div class="flex gap-6 items-start">
          <img src="/assets/img/courses/logo-typescript.svg" alt="TypeScript Logo" loading="lazy" class="w-16 h-16 flex-shrink-0" />
          <div>
            <h3 class="text-xl text-gray-900 dark:text-white mb-3">TypeScript</h3>
            <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
              TypeScript has been developed by Microsoft since 2012 and is a superset of JavaScript
              (the foundation of web application development). It extends JavaScript with a type system that greatly
              supports the development and maintenance of web applications. Developers who have previously learned
              programming languages like Java or C# will find it much easier to get started.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="relative" id="testimonial-slider">
          {testimonials.map((testimonial, index) => (
            <div
              class={`testimonial-slide ${index === 0 ? '' : 'hidden'}`}
              data-index={index}
            >
              <div class="flex flex-col md:flex-row gap-8 items-center">
                <div class="w-24 h-24 md:w-32 md:h-32 flex-shrink-0">
                  <img
                    src={testimonial.image}
                    alt={testimonial.name}
                    class="w-full h-full object-cover object-top rounded-full"
                    loading="lazy"
                  />
                </div>

                <div class="flex-1 text-center md:text-left">
                  <blockquote class="text-lg text-gray-700 dark:text-gray-300 italic mb-4">
                    "{testimonial.quote}"
                  </blockquote>
                  <div>
                    <p class="font-semibold text-gray-900 dark:text-white">{testimonial.name}</p>
                    <p class="text-sm text-gray-500 dark:text-gray-400">{testimonial.role}, {testimonial.company}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}

          <div class="flex justify-center gap-2 mt-6">
            {testimonials.map((_, index) => (
              <button
                class={`testimonial-dot w-2 h-2 rounded-full transition-colors ${index === 0 ? 'bg-primary' : 'bg-gray-300 dark:bg-gray-600'}`}
                data-target={index}
                aria-label={`Testimonial ${index + 1}`}
              ></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      let currentSlide = 0;
      const slides = document.querySelectorAll('.testimonial-slide');
      const dots = document.querySelectorAll('.testimonial-dot');
      const totalSlides = slides.length;

      function showSlide(index) {
        slides.forEach((slide, i) => {
          slide.classList.toggle('hidden', i !== index);
        });
        dots.forEach((dot, i) => {
          dot.classList.toggle('bg-primary', i === index);
          dot.classList.toggle('bg-gray-300', i !== index);
        });
        currentSlide = index;
      }

      dots.forEach(dot => {
        dot.addEventListener('click', () => {
          showSlide(parseInt(dot.dataset.target));
        });
      });

      setInterval(() => {
        showSlide((currentSlide + 1) % totalSlides);
      }, 6000);
    })();
  </script>

  <!-- Agenda Section -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto mb-16">
        <p class="text-sm font-semibold text-primary uppercase tracking-wide mb-3">Agenda</p>
        <h2 class="text-4xl md:text-5xl lg:text-6xl text-gray-900 dark:text-white mb-8 leading-tight">
          Knowledge from real-world practice.
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
          We are developers ourselves and know which problems arise first in the real world. That's why
          we work with examples from real-world scenarios, distilled to their core for easy understanding.
          <strong class="text-gray-900 dark:text-white">The hands-on portion is 60%</strong>.
        </p>
      </div>

      <div class="space-y-12 max-w-5xl mx-auto">
        <!-- TypeScript Basics -->
        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div class="flex gap-5">
            <img src="/assets/img/courses/logo-typescript.svg" alt="TypeScript" loading="lazy" class="w-14 h-14 flex-shrink-0" />
            <div>
              <h3 class="text-2xl text-gray-900 dark:text-white mb-3">TypeScript Fundamentals</h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                We start with a short introduction to TypeScript (approx. 3 hours), covering the
                basics needed for the subsequent {topic} portion.
              </p>
            </div>
          </div>
          <div class="space-y-1 md:pl-4">
            {['Why TypeScript?', 'Type Inference', 'Type Definitions', 'Interfaces & Type Aliases', 'Generics', 'Utility Types', 'Enums and Union Types', 'Best Practices'].map(item => (
              <div class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>

        <!-- React Fundamentals -->
        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div class="flex gap-5">
            <img src="/assets/img/courses/react-logo.svg" alt="React" loading="lazy" class="w-14 h-14 flex-shrink-0" />
            <div>
              <h3 class="text-2xl text-gray-900 dark:text-white mb-3">{topic} Components and Hooks</h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                Next, we work through the core concepts of {topic} along a continuous
                example application. Each topic includes a short theory portion followed by an exercise.
                We provide sample solutions for each step.
              </p>
            </div>
          </div>
          <div class="space-y-1 md:pl-4">
            {['What is React and how does JSX work?', 'Functional Components and Props', 'State with useState and useReducer', 'Side Effects with useEffect', 'Event Handling and Conditional Rendering', 'Lists and Keys', 'Component Architecture and Composition', 'Styling Strategies (CSS Modules, Tailwind, Styled Components)', 'React DevTools'].map(item => (
              <div class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>

        <!-- Routing & Data Fetching -->
        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div class="flex gap-5">
            <img src="/assets/img/courses/react-logo.svg" alt="React" loading="lazy" class="w-14 h-14 flex-shrink-0" />
            <div>
              <h3 class="text-2xl text-gray-900 dark:text-white mb-3">Routing and Data Fetching</h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                After the fundamentals, we expand our demo application with navigation and data integration.
              </p>
            </div>
          </div>
          <div class="space-y-1 md:pl-4">
            {['Client-side Routing with React Router', 'Dynamic Routes and URL Parameters', 'Nested Routes and Layouts', 'Data Loading and Suspense', 'REST API Access with fetch and Axios', 'Error Handling and Error Boundaries', 'Loading States and Optimistic Updates'].map(item => (
              <div class="flex items-center gap-3 text-gray-700 dark:text-gray-300">
                <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                {item}
              </div>
            ))}
          </div>
        </div>

        <!-- Forms & Validation -->
        <div class="grid md:grid-cols-2 gap-8 items-start">
          <div class="flex gap-5">
            <img src="/assets/img/courses/react-logo.svg" alt="React" loading="lazy" class="w-14 h-14 flex-shrink-0" />
            <div>
              <h3 class="text-2xl text-gray-900 dark:text-white mb-3">{topic} Forms and Validation</h3>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                Next, we cover the topics that form the core of virtually every application.
              </p>
            </div>
          </div>
          <div class="space-y-1 md:pl-4">
            {['Controlled vs. Uncontrolled Components', 'Form Handling with React Hook Form', 'Validation with Zod', 'Custom Form Components', 'React 19 Form Actions and useActionState'].map(item => (
