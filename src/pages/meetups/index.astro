---
import BaseLayout from '../../layouts/BaseLayout.astro';

const meetups = [
  { name: 'React Berlin', city: 'Berlin', url: 'https://www.meetup.com/React-Berlin/' },
  { name: 'React Munich', city: 'München', url: 'https://www.meetup.com/React-Munich/' },
  { name: 'React Hamburg', city: 'Hamburg', url: 'https://www.meetup.com/React-Hamburg/' },
  { name: 'React Cologne', city: 'Köln', url: 'https://www.meetup.com/React-Cologne/' },
  { name: 'React Frankfurt', city: 'Frankfurt', url: 'https://www.meetup.com/React-Frankfurt/' },
  { name: 'React Stuttgart', city: 'Stuttgart', url: 'https://www.meetup.com/React-Stuttgart/' },
  { name: 'React Vienna', city: 'Wien', url: 'https://www.meetup.com/React-Vienna/' },
  { name: 'React Zurich', city: 'Zürich', url: 'https://www.meetup.com/React-Zurich/' },
];
---

<BaseLayout
  title="React Meetups"
  description="Finde dein React Meetup in der DACH Region oder gründe selbst eins!"
>
  <!-- Hero Header with Pattern Background -->
  <section class="relative py-20 md:py-28 overflow-hidden dark:bg-gray-950">
    <!-- Gradient Mesh Background (Light) - React cyan/blue -->
    <div class="absolute inset-0 dark:hidden" style="background: radial-gradient(at 20% 30%, rgba(97, 218, 251, 0.08) 0px, transparent 50%), radial-gradient(at 80% 20%, rgba(59, 130, 246, 0.1) 0px, transparent 50%), radial-gradient(at 40% 80%, rgba(97, 218, 251, 0.06) 0px, transparent 50%), radial-gradient(at 90% 70%, rgba(54, 197, 232, 0.06) 0px, transparent 50%), linear-gradient(180deg, #fafafa 0%, #f5f5f5 100%);"></div>
    <!-- Gradient Mesh Background (Dark) -->
    <div class="absolute inset-0 hidden dark:block" style="background: radial-gradient(at 20% 30%, rgba(97, 218, 251, 0.2) 0px, transparent 50%), radial-gradient(at 80% 20%, rgba(59, 130, 246, 0.15) 0px, transparent 50%), radial-gradient(at 40% 80%, rgba(97, 218, 251, 0.12) 0px, transparent 50%);"></div>
    <!-- Dot Grid Pattern Overlay -->
    <div class="absolute inset-0 dark:opacity-30" style="background-image: radial-gradient(circle, rgba(0, 0, 0, 0.08) 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="container mx-auto px-4 relative text-center z-10">
      <h1 class="text-5xl md:text-6xl lg:text-7xl text-gray-900 dark:text-white mb-4">
        React Meetups in der DACH-Region
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Finde dein React Meetup in der DACH Region<br />
        und vernetze dich mit der Community.
      </p>
    </div>
  </section>

  <section class="py-12 dark:bg-gray-950">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-12">
        <p class="text-gray-600 dark:text-gray-400 mb-4">
          In der DACH-Region gibt es eine lebendige React Community mit regelmäßigen Meetups
          in vielen Städten. Hier kannst du dich mit anderen React-Entwickler:innen austauschen,
          von Vorträgen lernen und neue Kontakte knüpfen.
        </p>
        <p class="text-gray-600 dark:text-gray-400">
          Du möchtest ein Meetup in deiner Stadt gründen? Wir unterstützen dich gerne dabei!
          Kontaktiere uns über unseren <a href="/discord/" class="text-primary hover:underline">Discord</a>.
        </p>
      </div>

      <h2 class="text-2xl text-gray-900 dark:text-white mb-6">Meetups in der DACH Region</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {meetups.map(meetup => (
          <a
            href={meetup.url}
            target="_blank"
            rel="noopener"
            class="group p-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm hover:shadow-lg transition-all border border-gray-100 dark:border-gray-700"
          >
            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
              {meetup.name}
            </h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
              📍 {meetup.city}
            </p>
          </a>
        ))}
      </div>

      <div class="mt-12 bg-gray-50 dark:bg-gray-900 rounded-xl p-6">
        <h3 class="text-gray-900 dark:text-white mb-2">Dein Meetup ist nicht dabei?</h3>
        <p class="text-gray-600 dark:text-gray-400">
          Wenn du ein React Meetup organisierst und es hier gelistet haben möchtest,
          kontaktiere uns gerne über <a href="/discord/" class="text-primary hover:underline">Discord</a> oder erstelle einen
          Pull Request auf <a href="https://github.com/symetics/reactjs.de" target="_blank" rel="noopener" class="text-primary hover:underline">GitHub</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
